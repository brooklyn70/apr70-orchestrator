# Anthropic API key — used by orchestrator + Claude Code subprocess runner
ANTHROPIC_API_KEY=sk-ant-...

# Path to the orchestrator state directory (USAGE.jsonl, QUOTAS.json only)
# TASKS.md and BRIEF.md default to the site repo under ORCHESTRATOR_WORK_DIR.
ORCHESTRATOR_STATE_DIR=./state

# Path to a working git checkout where Claude Code subprocess runs.
# In production this points to /volume1/apps/apr70-pictures/ on the NAS.
ORCHESTRATOR_WORK_DIR=../apr70-pictures

# Optional: override paths (defaults: WORK_DIR/TASKS.md and WORK_DIR/BRIEF.md)
# ORCHESTRATOR_TASKS_PATH=../apr70-pictures/TASKS.md
# ORCHESTRATOR_BRIEF_PATH=../apr70-pictures/BRIEF.md

# Optional: model to use for one-shot tasks
ORCHESTRATOR_MODEL=claude-sonnet-4-5

# Optional: suppress duplicate Telegram ends for the same task within N seconds (default 240)
# ORCHESTRATOR_TELEGRAM_DEDUPE_SEC=240

# GitHub token for ephemeral HTTPS pushes inside the container ONLY (fine-grained: both repos contents write).
# Never put this PAT in git remote.origin.url — use deployment keys for host clones.
# Field is often "credential" (API Credential) or "password" (Login/Password); use stable item id from `op item list`.
GITHUB_TOKEN="op://VAULT/ITEM/password"
